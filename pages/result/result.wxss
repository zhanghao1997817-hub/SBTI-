/* pages/result/result.wxss */
.result-page {
  padding-bottom: 60rpx;
}

.result-card {
  padding: 32rpx;
}

/* 顶部布局 */
.result-top {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.poster-box {
  border: 1rpx solid var(--line);
  border-radius: 36rpx;
  padding: 24rpx;
  background:
    radial-gradient(circle at top right, rgba(127, 165, 134, 0.16), rgba(127, 165, 134, 0) 40%),
    linear-gradient(180deg, #ffffff, #f7fbf8);
  min-height: 400rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.poster-box.no-image {
  min-height: 160rpx;
}

.poster-image {
  width: 100%;
  height: 440rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.75);
}

.poster-caption {
  margin-top: 20rpx;
  color: var(--muted);
  font-size: 26rpx;
  line-height: 1.8;
  text-align: center;
}

.type-box {
  border: 1rpx solid var(--line);
  border-radius: 36rpx;
  padding: 32rpx;
  background: linear-gradient(180deg, #ffffff, #fbfdfb);
}

.type-kicker {
  font-size: 22rpx;
  color: var(--accent-strong);
  margin-bottom: 12rpx;
  letter-spacing: 0.06em;
  display: block;
}

.type-name {
  font-size: 56rpx;
  font-weight: 800;
  line-height: 1.2;
  letter-spacing: -0.03em;
  display: block;
}

.match-badge {
  margin-top: 28rpx;
  display: inline-flex;
  align-items: center;
  border-radius: 999rpx;
  padding: 16rpx 24rpx;
  background: var(--soft);
  border: 1rpx solid var(--line);
  color: var(--accent-strong);
  font-weight: 700;
  font-size: 26rpx;
}

.type-sub {
  margin-top: 16rpx;
  color: var(--muted);
  font-size: 26rpx;
  line-height: 1.8;
  display: block;
}

/* 解读 */
.analysis-box {
  border: 1rpx solid var(--line);
  border-radius: 36rpx;
  padding: 32rpx;
  background: linear-gradient(180deg, #ffffff, #fbfdfb);
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  display: block;
}

.analysis-text {
  color: #304034;
  font-size: 28rpx;
  line-height: 1.9;
  display: block;
  white-space: pre-wrap;
}

/* 维度 */
.dim-box {
  border: 1rpx solid var(--line);
  border-radius: 36rpx;
  padding: 32rpx;
  background: linear-gradient(180deg, #ffffff, #fbfdfb);
  margin-bottom: 24rpx;
}

.dim-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.dim-item {
  border: 1rpx solid var(--line);
  border-radius: 32rpx;
  padding: 24rpx;
  background: #fff;
}

.dim-item-top {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.dim-name {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text);
}

.dim-score {
  color: var(--accent-strong);
  font-weight: 800;
  font-size: 26rpx;
  white-space: nowrap;
}

.dim-desc {
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.8;
  display: block;
}

/* 友情提示 */
.note-box {
  border: 1rpx solid var(--line);
  border-radius: 36rpx;
  padding: 32rpx;
  background: linear-gradient(180deg, #ffffff, #fbfdfb);
  margin-bottom: 32rpx;
}

.note-text {
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.8;
  display: block;
}

/* 操作 */
.result-actions {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.result-actions .btn-primary,
.result-actions .btn-secondary {
  flex: 1;
  min-width: 200rpx;
}

.share-hint {
  margin-top: 24rpx;
  text-align: center;
}

.share-hint text {
  font-size: 22rpx;
  color: var(--muted);
}
