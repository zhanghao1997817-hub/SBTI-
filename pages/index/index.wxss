/* pages/index/index.wxss */
.index-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background:
    radial-gradient(circle at top left, #f8fff8 0, #f6faf6 36%, #f2f7f3 100%);
}

.hero {
  width: 100%;
  padding: 80rpx 40rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero::after {
  content: "";
  position: absolute;
  right: -60rpx;
  top: -60rpx;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(127, 165, 134, 0.18), rgba(127, 165, 134, 0.02));
  pointer-events: none;
}

.hero-inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-title {
  font-size: 56rpx;
  font-weight: 800;
  line-height: 1.3;
  letter-spacing: -0.03em;
  margin-bottom: 60rpx;
  color: var(--text);
}

.start-btn {
  width: 80%;
  margin-bottom: 60rpx;
}

.credit {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.credit-line {
  font-size: 24rpx;
  color: var(--muted);
  line-height: 1.6;
}
